# ─────────────────────────────────────────────
# Homelink – Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── Backend ──────────────────────────────────
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://homelink:homelink_secret@localhost:5432/homelink_db

# Redis
REDIS_URL=redis://localhost:6379

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=homelink_neo4j_secret

# JWT (generate strong secrets for production)
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_too

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Storage (MinIO/S3)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=homelink_minio
MINIO_SECRET_KEY=homelink_minio_secret
MINIO_PUBLIC_URL=http://localhost:9000

# URLs
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
